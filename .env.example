# NextAuth Configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Admin Credentials
ADMIN_USERNAME=admin
# Generate a password hash using: npx bcryptjs hash "your-password"
# Or use the default password "changeme123" for initial setup (CHANGE THIS!)
ADMIN_PASSWORD_HASH=

# Vercel KV (Redis) - Get these from your Vercel dashboard
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Vercel Blob Storage - Get this from your Vercel dashboard
BLOB_READ_WRITE_TOKEN=
